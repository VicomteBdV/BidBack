NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_ANVIL_RPC_URL=http://127.0.0.1:8545

# Server-side local Anvil access used by Next.js API routes.
ANVIL_RPC_URL=http://127.0.0.1:8545

# Local dev only. Use a non-seller Anvil private key printed by `anvil`.
# Do not use a real private key. Do not use the deployer/seller account.
ANVIL_DEV_BIDDER_PRIVATE_KEY=0x